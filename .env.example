DATABASE_URL=postgresql+psycopg://postgres@127.0.0.1:5432/agent_db

# 当前激活的 LLM 提供商
LLM_PROVIDER=ollama

# 通用超时（秒）
LLM_TIMEOUT_SEC=120

#Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen:7b

# Zhipu
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# 主 provider 失败时使用的备用 provider，留空表示不回退
LLM_FALLBACK_PROVIDER=ollama

# 行程/文档 word 文件输出目录（相对路径相对「启动 uvicorn 时的工作目录」，一般为 backend 根目录）
DOC_OUTPUT_DIR=var/generated_docs
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/agent_db

# 当前激活的 LLM 提供商
LLM_PROVIDER=zhipu

# 通用超时（秒）
LLM_TIMEOUT_SEC=120

#Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen:7b

# Zhipu
ZHIPU_API_KEY=aaa
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# MCP
MCP_SERVER_URL=http://127.0.0.1:6688
MCP_TIMEOUT_SECONDS=120
MCP_HTTP_PATH=/mcp
# MCP 工具返回后是否再用 LLM 润色为自然语言（true / false，默认 false）
MCP_REPLY_VIA_LLM=true

# 主 provider 失败时使用的备用 provider，留空表示不回退（建议小写 ollama）
LLM_FALLBACK_PROVIDER=ollama

# 行程/文档 word 文件输出目录（相对路径相对「启动 uvicorn 时的工作目录」，一般为 backend 根目录）
DOC_OUTPUT_DIR=var/generated_docs

# 最近最多读多少条消息（从新往旧取再反转为时间顺序）
MEMORY_RECENT_MESSAGE_ROWS=40
# 拼「最近对话」时总字符上限，防止 prompt 太长
MEMORY_RECENT_CHAR_BUDGET=8000
# 精炼触发阈值，每隔多少条消息触发一次精炼
MEMORY_REFINE_THRESHOLD_MESSAGES=12
# 精炼上下文消息条数，不要太多
MEMORY_REFINE_CONTEXT_MESSAGES=80